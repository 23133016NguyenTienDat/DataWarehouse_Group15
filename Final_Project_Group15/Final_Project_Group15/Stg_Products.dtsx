                    <arrayElement
                      dataType="System.String"><![CDATA[using System;
using System.Security.Cryptography;
using System.Text;
using Microsoft.SqlServer.Dts.Pipeline.Wrapper;
using Microsoft.SqlServer.Dts.Runtime.Wrapper;

[Microsoft.SqlServer.Dts.Pipeline.SSISScriptComponentEntryPointAttribute]
public class ScriptMain : UserComponent  // ← class này có sẵn, KHÔNG xóa
{
    // ✅ Khai báo ở đây — BÊN TRONG class
    private SHA256 _sha256;

    public override void PreExecute()
    {
        _sha256 = SHA256.Create();
    }

    public override void Input0_ProcessInputRow(Input0Buffer Row)
    {
        var sb = new StringBuilder();
        sb.Append(Row.productid ?? "").Append("|")
          .Append(Row.category ?? "").Append("|")
          .Append(Row.name ?? "").Append("|")
          .Append(Row.priceusd ?? "").Append("|")
          .Append(Row.costusd ?? "").Append("|")
          .Append(Row.marginusd ?? "");

        // Gán thẳng byte[] vì DB là VARBINARY(32)
        Row.rowhash = _sha256.ComputeHash(Encoding.UTF8.GetBytes(sb.ToString()));
    }

    public override void PostExecute()
    {
        _sha256?.Dispose();
    }
}  // ← đóng class ở đây]]></arrayElement>
