          SQLTask:SqlStatementSource="INSERT INTO adm.Etl_Package_Logs (batch_id, package_name, start_time)&#xA;VALUES (?, 'Stg_OrderItems', GETDATE());&#xA;SELECT SCOPE_IDENTITY() AS package_log_id;"
