        <SQLTask:SqlTaskData
          SQLTask:Connection="{253072E7-531F-4923-9EEC-0F7AA7B78C54}"
          SQLTask:SqlStatementSource="&#xA;UPDATE adm.Etl_Package_Logs &#xA;SET status = 'SUCCESS', end_time = GETDATE(), &#xA;    records_inserted = ?, records_error = ?&#xA;WHERE package_log_id = ?" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask">
          <SQLTask:ParameterBinding
            SQLTask:ParameterName="0"
