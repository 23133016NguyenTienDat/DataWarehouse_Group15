                  description="The SQL command to be executed."
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT *
FROM (
    SELECT *,
           CONVERT(DATETIME, REPLACE(LEFT(event_time, 19), 'T', ' ')) AS event_time_dt,
           ROW_NUMBER() OVER (
               PARTITION BY event_id
               ORDER BY event_time
           ) AS rn
    FROM stg.events
    WHERE is_valid = 1 
      AND is_processed = 0
) t
WHERE rn = 1</property>
                <property
