              description="OLE DB Source"
              name="OLE DB Source"
              usesDispositions="true"
              version="7">
              <properties>
                <property
                  dataType="System.Int32"
                  description="The number of seconds before a command times out.  A value of 0 indicates an infinite time-out."
                  name="CommandTimeout">0</property>
                <property
                  dataType="System.String"
                  description="Specifies the name of the database object used to open a rowset."
                  name="OpenRowset"></property>
                <property
                  dataType="System.String"
                  description="Specifies the variable that contains the name of the database object used to open a rowset."
                  name="OpenRowsetVariable"></property>
                <property
                  dataType="System.String"
                  description="The SQL command to be executed."
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">WITH web_funnel AS (
    SELECT
        customer_key,
        product_key,
        MIN(CASE WHEN event_type = 'page_view'   THEN date_key END) AS first_view_date_key,
        MIN(CASE WHEN event_type = 'add_to_cart' THEN date_key END) AS first_add_to_cart_date_key
    FROM dw.fact_web_events
    WHERE product_key IS NOT NULL
    GROUP BY customer_key, product_key
    HAVING MIN(CASE WHEN event_type = 'page_view' THEN date_key END) IS NOT NULL
),
purchases AS (
    SELECT
        customer_key,
        product_key,
        MIN(date_key) AS first_purchase_date_key
    FROM dw.fact_order_item
    GROUP BY customer_key, product_key
)
SELECT
    w.customer_key,
    w.product_key,
    w.first_view_date_key,
    w.first_add_to_cart_date_key,
    p.first_purchase_date_key    -- bỏ NULL AS first_checkout_date_key
FROM web_funnel w
LEFT JOIN purchases p
    ON  p.customer_key = w.customer_key
    AND p.product_key  = w.product_key</property>
                <property
